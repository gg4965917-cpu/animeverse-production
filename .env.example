# AnimeVerse - Конфігурація

# ========== SERVER ==========
PORT=3000
NODE_ENV=development

# ========== TELEGRAM BOT ==========
# Отримай токен від @BotFather в Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Приклад формату:
# TELEGRAM_BOT_TOKEN=123456789:ABCDefghIjklmnopQRStuvwxyZ1234567890

# ========== URLS ==========
# Локально:
API_URL=http://localhost:3000
SITE_URL=http://localhost:5173

# На production (Railway + Vercel):
# API_URL=https://your-api.railway.app
# SITE_URL=https://your-site.vercel.app

# ========== DATABASE (для майбутнього) ==========
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/anime

# ========== GOOGLE TTS (опціонально) ==========
# GOOGLE_TTS_API_KEY=your_key_here

# ========== DEBUG ==========
DEBUG=false
LOG_LEVEL=info

# Примечания:
# 1. Скопіюй цей файл як .env і заповни свої значення
# 2. НІКОЛИ не комітуй .env в git!
# 3. На Railway додай ці змінні через дашборд
# 4. На Vercel додай як Environment Variables
